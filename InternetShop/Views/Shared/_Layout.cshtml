<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] специализированный игровой интернет-магазин</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">
    
    <style>
        html, body {
            height: 100%;
            margin: 0;
            padding: 0;
        }
        
        body {
            padding-top: 20px;
            padding-bottom: 20px;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }
        
        .container {
            flex: 1 0 auto;
            width: 100%;
        }
        
        .navbar-custom {
            background-color: gray;
            border-radius: 0.25rem;
            padding: 0.5rem 1rem;
        }
        
        .navbar-brand-custom {
            display: flex;
            align-items: center;
            text-decoration: none;
            color: black;
            font-weight: bold;
            margin-right: 1rem;
        }
        .navbar-brand-custom:hover {
            color: black;
        }
        
        .store-name {
            font-size: 1.25rem;
            white-space: normal;
            line-height: 1.2;
            color: black;
        }
        
        @@media (max-width: 992px) {
            .store-name {
                font-size: 1rem;
            }
        }
        
        @@media (max-width: 768px) {
            .navbar-brand-custom {
                flex-wrap: wrap;
            }
            .store-name {
                margin-top: 5px;
                width: 100%;
            }
        }
        
        /* ВКЛАДКИ БЕЛЫМ ЦВЕТОМ */
        .navbar-nav .nav-link {
            color: white !important;
        }
        .navbar-nav .nav-link.active {
            color: white !important;
            font-weight: 500;
            text-decoration: underline;
        }
        .navbar-nav .nav-link:hover {
            color: #cfe2ff !important;
        }
        
        /* НОВЫЙ ЦВЕТ - как в блоке приветствия */
        .table-primary {
            --bs-table-bg: #cfe2ff !important;
            --bs-table-color: #084298 !important;
            --bs-table-striped-bg: #cfe2ff !important;
            --bs-table-striped-color: #084298 !important;
            --bs-table-hover-bg: #cfe2ff !important;
            --bs-table-hover-color: #084298 !important;
        }
        
        .alert-info {
            --bs-alert-bg: #cfe2ff !important;
            --bs-alert-border-color: #084298 !important;
            --bs-alert-color: black !important;
        }
        
        /* ФОН ДЛЯ КОНТАКТНАЯ ИНФОРМАЦИЯ */
        .card-header.bg-primary {
            background-color: #cfe2ff !important;
            color: black !important;  /* НАДПИСЬ ЧЕРНЫМ ЦВЕТОМ */
        }
        
        .btn-primary {
            background-color: #cfe2ff;
            border-color: #084298;
            color: #084298;
        }
        .btn-primary:hover {
            background-color: #b8d4ff;
            border-color: #084298;
            color: #084298;
        }
        
        .btn-secondary {
            background-color: gray;
            border-color: gray;
            color: white;
        }
        .btn-secondary:hover {
            background-color: darkgray;
            border-color: darkgray;
        }
        
        /* ЦЕНЫ ЧЕРНЫМ ЦВЕТОМ */
        .text-primary {
            color: black !important;
            font-weight: normal !important;
        }
        
        /* Убираем жирное выделение для названий товаров */
        td strong {
            font-weight: normal !important;
        }
        
        /* ДЛЯ ТАБЛИЦЫ PRODUCTS */
        .table td, .table th {
            color: black;
        }
        
        /* ПОДВАЛ ПО ЦЕНТРУ И ВНИЗУ */
        .footer {
            margin-top: 30px;
            padding: 20px 0;
            background-color: white;
            border-top: 1px solid white;
            width: 100%;
            flex-shrink: 0;
        }
        
        .footer .row {
            justify-content: center;
        }
        
        .footer .col-10 {
            flex: 0 0 auto;
            width: auto;
            max-width: 100%;
            text-align: center;
        }
        
        .bg-custom-blue {
            background-color: #cfe2ff !important;
            color: #084298 !important;
        }
        
        .text-custom-blue {
            color: #084298 !important;
        }
        
        .btn-custom-blue {
            background-color: #cfe2ff !important;
            color: #084298 !important;
            border: 1px solid #084298 !important;
        }
        
        .btn-custom-blue:hover {
            background-color: #b8d4ff !important;
        }
        
        .table-custom thead {
            background-color: #cfe2ff !important;
            color: #084298 !important;
        }
        
        .table-custom thead th {
            color: #084298 !important;
        }
        
        .alert-custom {
            background-color: white !important;
            border: 1px solid darkgray !important;
            color: red !important;
        }
    </style>
</head>
<body>
    <div class="container">
        <nav class="navbar navbar-expand-lg navbar-custom" aria-label="Навигация">
            <div class="container-fluid">
                <a class="navbar-brand-custom" href="/">
                    <img src="https://www.sotcomm.ru/wp-content/uploads/2021/08/logo_sotcomm_2-min.png" 
                         alt="SOTCOMM" 
                         width="300" 
                         height="100"
                         style="margin-right: 15px;">
                    <span class="store-name">Специализированный игровой интернет-магазин SOTCOMM</span>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarsExample" aria-controls="navbarsExample" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarsExample">
                    <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")" href="/">Главная</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Products" ? "active" : "")" href="/Home/Products">Товары</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Contact" ? "active" : "")" href="/Home/Contact">Контакты</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>

        <div class="row mt-4">
            <div class="col-12">
                <h1 class="display-6">@ViewData["Title"]</h1>
                <hr class="my-4" />
            </div>
        </div>

        <main role="main">
            @RenderBody()
        </main>

        <footer class="footer">
            <div class="container">
                <div class="row">
                    <div class="col-10">
                        <p>&copy; 2026 - Интернет-магазин SOTCOMM. Все права защищены.</p>
                    </div>
                </div>
            </div>
        </footer>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL" crossorigin="anonymous"></script>
</body>
</html>