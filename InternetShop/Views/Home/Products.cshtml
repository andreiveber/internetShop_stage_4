@model List<InternetShop.Models.Product>

@{
    Layout = "_Layout";
}

<div class="row mb-4">
    <div class="col-12">
        <div class="card">
            <div class="card-body bg-light">
                <form method="get" action="/Home/Products" class="row g-3">
                    <div class="col-md-8">
                        <label for="search" class="form-label">Поиск по названию:</label>
                        <input type="text" class="form-control" id="search" name="search"
                               placeholder="Введите название товара..."
                               value="@Context.Request.Query["search"]">
                    </div>
                    <div class="col-md-4 d-flex align-items-end">
                        <button type="submit" class="btn btn-primary me-2">Найти</button>
                        @if (!string.IsNullOrEmpty(Context.Request.Query["search"]))
                        {
                            <a href="/Home/Products" class="btn btn-secondary">Сбросить</a>
                        }
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        @{
            var searchTerm = Context.Request.Query["search"].ToString().ToLower();
            var filteredProducts = string.IsNullOrEmpty(searchTerm)
                ? Model
                : Model.Where(p => p.Name.ToLower().Contains(searchTerm)).ToList();
        }

        @if (filteredProducts.Any())
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-primary">
                        <tr>
                            <th scope="col">ID</th>
                            <th scope="col">Название</th>
                            <th scope="col">Цена</th>
                            <th scope="col">Описание</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var product in filteredProducts)
                        {
                            <tr>
                                <td>@product.Id</td>
                                <td><strong>@product.Name</strong></td>
                                <td class="text-primary fw-bold">@product.Price.ToString("C")</td>
                                <td>@product.Description</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            
            <div class="alert alert-info">
                <strong>Всего товаров:</strong> @Model.Count
                @if (!string.IsNullOrEmpty(Context.Request.Query["search"]))
                {
                    <span> | <strong>Найдено:</strong> @filteredProducts.Count</span>
                }
            </div>
        }
        else
        {
            <div class="alert alert-danger">
                <strong>Товары не найдены.</strong> Попробуйте изменить параметры поиска.
            </div>
        }
    </div>
</div>